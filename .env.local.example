# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API)

# Your project URL, e.g. https://abcdefghijklmno.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / public API key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The team/site display name shown in the header and titles
NEXT_PUBLIC_TEAM_NAME=Mundo Rainbows

# Optional: bump this to control the season label shown on the site
NEXT_PUBLIC_SEASON=Fall 2026

# Public URL of the deployed site (used in WhatsApp share messages)
NEXT_PUBLIC_SITE_URL=https://mundorainbows.com

# Optional: public URL of the team crest image (nav bar, sign-in, watermark)
NEXT_PUBLIC_LOGO_URL=
